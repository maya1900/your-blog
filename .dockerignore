# Keep build contexts small and avoid leaking secrets.

# Dependencies & build artifacts (will be rebuilt inside images)
node_modules
**/node_modules
**/dist
**/build
**/.turbo

# Secrets — never bake into images
.env
.env.*
!.env.production.example
!.env.example

# Local runtime data
server/uploads/*
!server/uploads/.gitkeep

# Git + IDE + OS
.git
.gitignore
.idea
.vscode
.DS_Store

# Docs & design assets — not needed in containers
mockups
docs
README.md
CHANGELOG.md
LICENSE

# Test scripts (not run in containers)
scripts/test-*.sh

# Logs
*.log
.pnpm-store
