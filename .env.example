# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=4000

# CORS - 允许的前端 origin
CLIENT_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=dev-only-secret-change-this-in-production-min-16-chars
JWT_EXPIRES_IN=7d

# Unsplash API (可选,用于写作页封面搜索/随机图)
UNSPLASH_ACCESS_KEY=

# ============================================
# Database (匹配 docker-compose.yml 默认值)
# ============================================
DATABASE_URL="mysql://blog:blogpass@localhost:3306/your_blog_dev"

# ============================================
# Client (Vite 注入)
# ============================================
# 留空走 vite proxy(开发推荐),生产填完整 URL
VITE_API_BASE_URL=
