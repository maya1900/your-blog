# ============================================
# 复制为 .env.production,把所有 __change_me__ 改成真实值
# ============================================

# ---- Server ----
NODE_ENV=production
JWT_SECRET=__CHANGE_ME__please_use_at_least_32_random_chars__
JWT_EXPIRES_IN=7d
# 浏览器访问的入口 — 单机部署一般就是 http://localhost,有域名就改成 https://your.domain
CLIENT_ORIGIN=http://localhost

# ---- MySQL (compose 内部使用) ----
MYSQL_ROOT_PASSWORD=__change_me__root__
MYSQL_DATABASE=your_blog_prod
MYSQL_USER=blog
MYSQL_PASSWORD=__change_me__blog__

# ---- Server → MySQL 连接 ----
# 容器互联用 service 名 "mysql" 作 host,密码必须与 MYSQL_PASSWORD 一致
DATABASE_URL=mysql://blog:__change_me__blog__@mysql:3306/your_blog_prod

# ---- 宿主机端口 ----
HTTP_PORT=80
