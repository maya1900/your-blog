{
  "name": "@your-blog/server",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../.env -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prisma": "dotenv -e ../.env -- prisma",
    "db:seed": "dotenv -e ../.env -- tsx prisma/seed.ts",
    "db:seed-articles": "dotenv -e ../.env -- tsx prisma/seed-articles.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
